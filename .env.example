# Data Learn — environment variables
#
# Copy this file to `.env` for local dev, or set these in your Vercel
# project's Environment Variables panel for Preview / Production.
# DO NOT commit a real `.env` to git — `.gitignore` already excludes it.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Connection string used at runtime. On Neon use the POOLED url — the
# hostname includes `-pooler` (e.g. ep-cool-name-12345-pooler.us-east-2
# .aws.neon.tech) and the connection string ends with `?sslmode=require`.
# On local dev use your direct localhost URL.
DATABASE_URL="postgresql://USER@localhost:5432/datalearn"

# Direct (non-pooled) URL used by `prisma migrate`. PgBouncer transaction-mode
# pools don't support DDL statements, so migrations need a direct connection.
# On Neon: same hostname WITHOUT `-pooler` (e.g. ep-cool-name-12345.us-east-2
# .aws.neon.tech). On local dev this is the same as DATABASE_URL.
DIRECT_URL="postgresql://USER@localhost:5432/datalearn"

# -----------------------------------------------------------------------------
# Auth (NextAuth v5)
# -----------------------------------------------------------------------------

# Random 32+ byte secret used to sign session JWTs. Generate one fresh per env:
#   openssl rand -base64 32
# NEVER share between dev and prod.
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# GitHub OAuth app — https://github.com/settings/developers
# Add a callback URL per environment:
#   local:   http://localhost:3000/api/auth/callback/github
#   prod:    https://<your-domain>/api/auth/callback/github
#   preview: https://*.vercel.app/api/auth/callback/github (wildcard not allowed;
#            either add each preview URL or use a dev-only OAuth app for previews)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth client — https://console.cloud.google.com/apis/credentials
# Same callback-URL pattern as GitHub.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# Admin API (Bearer key auth)
# -----------------------------------------------------------------------------

# HMAC pepper used to hash admin API keys at rest. Without this, raw API key
# strings stored in the DB would be the plaintext bearer; with it, an attacker
# who reads the DB can't use the keys without the secret.
# Generate fresh per env: openssl rand -hex 32
API_KEY_HASH_SECRET="generate-with-openssl-rand-hex-32"
