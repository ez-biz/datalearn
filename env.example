# Database
# Local Postgres (example): postgresql://user:pass@localhost:5432/datalearn
# Neon: pooled connection string (used by the app at runtime)
DATABASE_URL=

# Direct (non-pooled) Postgres URL — required on Neon for `prisma migrate deploy`.
# For local dev you can leave this unset; for prod set it to Neon's direct connection string.
DIRECT_URL=

# NextAuth
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Production: set NEXTAUTH_URL to the Vercel production URL
# (NextAuth 5 reads this for OAuth callback construction)
NEXTAUTH_URL=
