generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  submissions   Submission[]
  apiKeys       ApiKey[]
  reports       ProblemReport[]
  articles      Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  CONTRIBUTOR
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Topic {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  content         String        @db.Text
  status          ArticleStatus @default(DRAFT)
  summary         String?       @db.Text
  readingMinutes  Int?
  reviewNotes     String?       @db.Text
  reviewedAt      DateTime?
  reviewedBy      String?
  topicId         String
  topic           Topic         @relation(fields: [topicId], references: [id])
  authorId        String
  author          User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  tags            Tag[]         @relation("ArticleTags")
  relatedProblems SQLProblem[]  @relation("ArticleProblems")
  versions        ArticleVersion[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([topicId, status])
  @@index([authorId])
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  ARCHIVED
}

/**
 * Immutable snapshot of an article at the moment it was published.
 * Created automatically on transitions to PUBLISHED.
 */
model ArticleVersion {
  id            String   @id @default(cuid())
  articleId     String
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  versionNumber Int
  title         String
  slug          String
  content       String   @db.Text
  summary       String?  @db.Text
  topicId       String
  tagSlugs      String[]
  relatedProblemSlugs String[]
  publishedById String?
  capturedAt    DateTime @default(now())

  @@unique([articleId, versionNumber])
  @@index([articleId, capturedAt])
}

model SqlSchema {
  id        String       @id @default(cuid())
  name      String       @unique
  sql       String       @db.Text
  problems  SQLProblem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model SQLProblem {
  id                String     @id @default(cuid())
  /// Stable monotonic id for display (`#247.` LeetCode-style). Minted at
  /// create-time as MAX(number)+1 in a transaction; never recycled even
  /// after archive. Backfill on existing rows ordered by createdAt ASC.
  number            Int        @unique
  title             String
  slug              String     @unique
  difficulty        Difficulty
  status            ProblemStatus @default(PUBLISHED)
  description       String     @db.Text
  schemaDescription String     @db.Text
  schemaId          String
  schema            SqlSchema  @relation(fields: [schemaId], references: [id])
  expectedOutput    String     @db.Text
  solutionSql       String?    @db.Text
  ordered           Boolean    @default(false)
  hints             String[]   @default([])
  tags              Tag[]      @relation("ProblemTags")
  submissions       Submission[]
  reports           ProblemReport[]
  relatedArticles   Article[]  @relation("ArticleProblems")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status])
}

enum ProblemStatus {
  DRAFT
  BETA
  PUBLISHED
  ARCHIVED
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  problems  SQLProblem[] @relation("ProblemTags")
  articles  Article[]    @relation("ArticleTags")
  createdAt DateTime     @default(now())
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Submission {
  id        String           @id @default(cuid())
  userId    String
  problemId String
  status    SubmissionStatus
  code      String           @db.Text
  reason    String?          @db.Text
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   SQLProblem       @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([userId, problemId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, status])
}

enum SubmissionStatus {
  ACCEPTED
  WRONG_ANSWER
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String?  @db.Text
  isActive    Boolean  @default(true)
  contentType String   @default("markdown") // 'markdown', 'custom'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String    // first 8 chars of plaintext, for display
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdById String
  createdBy  User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([createdById])
}

model ProblemReport {
  id         String              @id @default(cuid())
  problemId  String
  problem    SQLProblem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  kind       ProblemReportKind
  message    String              @db.Text
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime            @default(now())

  @@index([resolvedAt])
  @@index([problemId, createdAt])
}

enum ProblemReportKind {
  WRONG_ANSWER
  UNCLEAR_DESCRIPTION
  BROKEN_SCHEMA
  TYPO
  OTHER
}
